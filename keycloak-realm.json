{
  "realm": "quarkus",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "quarkus-app",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      }
    ]
  },
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    },
    {
      "username": "bob",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    }
  ]
}
